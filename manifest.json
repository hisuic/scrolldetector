{
  "manifest_version": 3,
  "name": "ScrollDetector",
  "version": "0.1.0",
  "description": "Shows a warning every 5 minutes while browsing social media or YouTube Shorts.",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "scrolldetector@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
